---
import Layout from '../layouts/Layout.astro';
import heroVideo from '../assets/hero.webm'
---

<Layout>
  <main class="h-80 md:h-[190vh]">
    <section class="pt-15 flex flex-col items-center justify-center">
      <div class="animate-delayed-fade flex flex-col text-center items-center md:w-[60%] w-[80%]">
        <p>
          iPhone 14 Pro and iPhone 14 Pro Max
        </p>
        <h1 class="text-6xl font-bold">
          It’s a leap <span class="block">year</span>
        </h1>
      </div>
      <video
        autoplay
        muted
        playsinline
        class="w-full pt-2"
      >
        <source src={heroVideo} type="video/webm" />
      </video>
      <div class="animate-delayed-fade pt-5 text-purple-300 text-2xl">
        <a href="">Learn More &gt; </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-delayed-fade {
    opacity: 0;
    animation: fadeIn 1.2s ease forwards;
    animation-delay: 4s;
  }
</style>